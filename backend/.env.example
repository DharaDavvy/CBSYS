# ── Firebase ─────────────────────────────────────────────────────────
# Path to the Firebase Admin SDK service-account JSON file.
# Can be relative to backend/ or absolute.
# On Render: set this as a secret file and reference the path here.
FIREBASE_CREDENTIALS=cbsys-a69e2-firebase-adminsdk-fbsvc-63a48f8acc.json

# ── Ollama (local inference) ──────────────────────────────────────────
# Leave blank on Render (Ollama is local-only; HF/Groq/Gemini are used instead).
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ── Cloud LLM fallbacks (leave blank if not using) ───────────────────
# Groq — https://console.groq.com/keys
GROQ_API_KEY=

# Google Gemini — https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=

# Hugging Face Inference API — https://huggingface.co/settings/tokens
# Required on Render for both embeddings (ingest + search) and LLM fallback.
HF_API_TOKEN=

# ── CORS (optional) ───────────────────────────────────────────────────
# Space-separated list of extra allowed origins beyond the built-in defaults.
# Built-in defaults: http://localhost:5173, https://cbsys.onrender.com
# CORS_EXTRA_ORIGINS=
