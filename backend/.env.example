# ── Firebase ─────────────────────────────────────────────────────────
# Path to the Firebase Admin SDK service-account JSON file.
# Can be relative to backend/ or absolute.
FIREBASE_CREDENTIALS=cbsys-a69e2-firebase-adminsdk-fbsvc-63a48f8acc.json

# ── Ollama (local inference) ──────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ── Cloud LLM fallbacks (leave blank if not using) ───────────────────
# Groq — https://console.groq.com/keys
GROQ_API_KEY=

# Google Gemini — https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=

# Hugging Face Inference API — https://huggingface.co/settings/tokens
HF_API_TOKEN=
